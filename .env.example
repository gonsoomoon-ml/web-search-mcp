# Web Search MCP — Environment Configuration Template
#
# 1. Copy to .env:  cp .env.example .env
# 2. TAVILY_API_KEY 만 직접 입력 (https://app.tavily.com — 무료 1,000 크레딧/월)
# 3. NEVER commit .env to git (이미 .gitignore 에 포함)
# 4. infra/web-search-gateway/deploy.sh 가 Cognito/Gateway 값을 자동 채움

# ============================================================
# AWS Configuration
# ============================================================
AWS_REGION=us-east-1

# ============================================================
# DEMO_USER (multi-tenant prefix)
# ============================================================
# 동일 AWS 계정에 여러 명이 배포할 때 충돌 방지용 식별자.
# CFN 스택 / Cognito / Gateway 이름 prefix 에 포함 (web-search-${DEMO_USER}-gateway 등).
# 미설정 시 deploy.sh 가 OS user($USER)로 fallback. 소문자/숫자/하이픈만, ≤16자 (Cognito Domain 제약).
DEMO_USER=

# ============================================================
# Tavily — web_search Lambda 가 호출 (직접 입력 필요)
# ============================================================
# deploy.sh 가 CFN NoEcho 파라미터로 Lambda 환경변수에 주입.
TAVILY_API_KEY=

# ============================================================
# Cognito (deploy.sh 가 자동 채움)
# ============================================================
COGNITO_USER_POOL_ID=
COGNITO_DOMAIN=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
# 형식: web-search-${DEMO_USER}-resource-server/invoke
COGNITO_GATEWAY_SCOPE=

# ============================================================
# AgentCore Gateway + Lambda ARN (deploy.sh 가 자동 채움)
# ============================================================
GATEWAY_ID=
GATEWAY_URL=
LAMBDA_WEB_SEARCH_ARN=
